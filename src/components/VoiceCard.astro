---
export interface Props {
  quote: string;
  name: string;
  street: string;
}
const { quote, name, street } = Astro.props;
const initial = name[0].toUpperCase();
---

<div class="voice-card">
  <p class="voice-quote">{quote}</p>
  <div class="voice-attribution">
    <div class="voice-initial">{initial}</div>
    <div class="voice-meta">
      <strong>{name}</strong>
      <span>{street}</span>
    </div>
  </div>
</div>

<style>
  .voice-card {
    background: rgba(245,239,224,0.04);
    border: 1px solid rgba(245,239,224,0.08);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, border-color 0.2s;
  }

  .voice-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .voice-card:hover {
    border-color: rgba(200,40,26,0.3);
  }

  .voice-quote {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(245,239,224,0.8);
    flex: 1;
  }

  .voice-attribution {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .voice-initial {
    width: 2.2rem;
    height: 2.2rem;
    background: rgba(200,40,26,0.2);
    border: 1px solid rgba(200,40,26,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    color: var(--red);
    flex-shrink: 0;
  }

  .voice-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .voice-meta strong {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--cream);
  }

  .voice-meta span {
    font-size: 0.75rem;
    color: rgba(245,239,224,0.4);
    letter-spacing: 0.06em;
  }
</style>
