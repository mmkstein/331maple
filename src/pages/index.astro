<script>
  // Share button
  const shareBtn = document.getElementById('hero-share');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const data = { title: '331 Maple St', text: 'A 12-story luxury tower is planned for Prospect Lefferts Gardens. Sign the petition and help stop it.', url: window.location.href };
      if (navigator.share) {
        try { await navigator.share(data); } catch {}
      } else {
        try { await navigator.clipboard.writeText(window.location.href); } catch {}
        shareBtn.textContent = 'Link Copied!';
        setTimeout(() => { (shareBtn as HTMLButtonElement).textContent = '↗ Share This Page'; }, 1800);
      }
    });
  }

  // Protected email links — sets href at runtime so address never appears in HTML source
  (() => {
    const u = 'amy.qing.lin';
    const d = 'gmail.com';
    document.querySelectorAll<HTMLAnchorElement>('.protected-email').forEach(a => {
      a.href = `mailto:${u}@${d}`;
    });
    // Join the Effort card — 7th help card link
    const joinLink = document.querySelector<HTMLAnchorElement>('.help-card:nth-child(7) .card-link');
    if (joinLink) joinLink.href = `mailto:${u}@${d}?subject=I want to get involved — 331 Maple St`;
  })();

  // Accordion
  document.querySelectorAll('.accordion-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.accordion-item')?.classList.toggle('open');
    });
  });

  // Copy email
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.emailId;
      if (!id) return;
      const bodyEl = document.getElementById(id);
      const block = bodyEl?.closest('.email-block');
      const subjectEl = block?.querySelector('.email-subject');
      const bodyText = bodyEl?.textContent?.trim() ?? '';
      const subjectText = subjectEl?.textContent?.replace(/^Subject:\s*/i, '').trim() ?? '';
      const text = subjectText ? `Subject: ${subjectText}\n\n${bodyText}` : bodyText;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'absolute'; ta.style.left = '-9999px';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
      }
      btn.classList.add('copied'); btn.textContent = 'Copied';
      setTimeout(() => { btn.classList.remove('copied'); btn.textContent = 'Copy Email'; }, 1400);
    });
  });

  // Expand email
  document.querySelectorAll<HTMLButtonElement>('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.emailId;
      const bodyEl = id ? document.getElementById(id) : null;
      if (!bodyEl) return;
      const expanded = bodyEl.classList.toggle('expanded');
      btn.textContent = expanded ? 'Read Less' : 'Read More';
    });
  });

  // Scroll reveal
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(el => el.classList.add('visible')); return; }
    const obs = new IntersectionObserver((entries, o) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); o.unobserve(e.target); } });
    }, { threshold: 0.08 });
    els.forEach(el => obs.observe(el));
  });
</script>

